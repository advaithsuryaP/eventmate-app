{
  "name": "eventmate-app-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["eventmate-app"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/eventmate-app-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["eventmate-app:build", "eventmate-app:serve"]
    }
  }
}
